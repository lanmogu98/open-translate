{
  "name": "open-translate",
  "version": "0.1.1",
  "private": true,
  "description": "Open Translate — immersive bilingual translation Chrome extension",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts/hooks",
    "build:config": "node scripts/build-config.js",
    "pretest": "npm run build:config",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "package": "bash scripts/package-release.sh"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "js-yaml": "^4.1.0",
    "sharp": "^0.34.5"
  }
}
